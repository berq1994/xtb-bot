# Local PowerShell / local testing
TELEGRAM_BOT_TOKEN=sem_vloz_token_bota
TELEGRAM_CHAT_ID=sem_vloz_chat_id
TELEGRAM_SEND_ENABLED=true

FMP_API_KEY=sem_vloz_fmp_klic

# Telegram portfolio alerts
PORTFOLIO_ALERT_MIN_MOVE=2.4
PORTFOLIO_ALERT_COOLDOWN_MIN=180
PORTFOLIO_ALERT_MAX_ITEMS=5

# Email digest (SMTP or Gmail fallback)
EMAIL_SEND_ENABLED=true
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=sem_vloz_email
EMAIL_SMTP_PASS=sem_vloz_heslo_nebo_app_password
EMAIL_FROM=sem_vloz_odesilatele
EMAIL_TO=sem_vloz_prijemce

# Starší kompatibilní proměnné
EMAIL_ENABLED=true
EMAIL_SENDER=sem_vloz_email
EMAIL_RECEIVER=sem_vloz_prijemce
GMAILPASSWORD=sem_vloz_heslo_nebo_app_password
