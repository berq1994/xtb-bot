{
  "config": {
    "app": {
      "env": "paper",
      "timezone": "Europe/Prague",
      "app_name": "xtb-bot",
      "safe_mode_on_error": true
    },
    "telegram": {
      "send_enabled": false,
      "timeout_sec": 15
    },
    "logging": {
      "level": "INFO",
      "dir": "logs",
      "file": "production.log",
      "max_bytes": 1048576,
      "backup_count": 3
    },
    "runner": {
      "retry_attempts": 3,
      "retry_backoff_sec": 2,
      "require_secrets_for_prod": true
    }
  },
  "validation": {
    "ok": true,
    "env": "paper",
    "telegram": {
      "bot_token_present": false,
      "chat_id_present": false
    },
    "reasons": [
      "OK"
    ]
  }
}